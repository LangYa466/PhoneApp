    <style name="ThemeOverlay.CallerID.Orange" parent="">
        <item name="colorPrimary">#E8710A</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#FFDCC2</item>
        <item name="colorOnPrimaryContainer">#2D1600</item>
