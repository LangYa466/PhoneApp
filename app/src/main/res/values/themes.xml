<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="InCallDialpadRow" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="DialerRow" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="Theme.CallerID" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" >true</item>
    </style>

    <!-- Color seed overlays — applied on top of Theme.CallerID -->
    <style name="ThemeOverlay.CallerID.Blue" parent="">
        <item name="colorPrimary">#1A73E8</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#D3E3FD</item>
        <item name="colorOnPrimaryContainer">#001D35</item>
        <item name="colorSecondary">#535F70</item>
        <item name="colorSecondaryContainer">#D7E3F7</item>
    </style>

    <style name="ThemeOverlay.CallerID.Green" parent="">
        <item name="colorPrimary">#2E7D32</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#B8F0BC</item>
        <item name="colorOnPrimaryContainer">#002106</item>
        <item name="colorSecondary">#52634F</item>
        <item name="colorSecondaryContainer">#D5E8CF</item>
    </style>

    <style name="ThemeOverlay.CallerID.Purple" parent="">
        <item name="colorPrimary">#6750A4</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#EADDFF</item>
        <item name="colorOnPrimaryContainer">#21005D</item>
        <item name="colorSecondary">#625B71</item>
        <item name="colorSecondaryContainer">#E8DEF8</item>
    </style>

    <style name="ThemeOverlay.CallerID.Red" parent="">
        <item name="colorPrimary">#C5221F</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#FFDAD6</item>
        <item name="colorOnPrimaryContainer">#410002</item>
