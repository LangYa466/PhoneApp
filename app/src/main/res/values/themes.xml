<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="InCallDialpadRow" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="DialerRow" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="Theme.CallerID" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" >true</item>
    </style>

    <!--
        颜色派生不在 XML 里写 overlay 了 改由 ThemeManager.applyColor() 在每个
        Activity onCreate super 之前调用 DynamicColorsOptions 用种子色生成完整
        MD3 tonal palette (覆盖全部 30+ 颜色 slot 不只是 primary)
    -->
</resources>
