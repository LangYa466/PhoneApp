<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/pref_category_appearance">
        <ListPreference
            app:key="theme_mode"
            app:title="@string/pref_theme_mode"
            app:entries="@array/theme_mode_entries"
            app:entryValues="@array/theme_mode_values"
            app:defaultValue="system"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            app:key="theme_color"
            app:title="@string/pref_theme_color"
            app:entries="@array/theme_color_entries"
            app:entryValues="@array/theme_color_values"
            app:defaultValue="dynamic"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/pref_category_phone">
        <Preference
            app:key="default_dialer"
            app:title="@string/pref_default_dialer" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/pref_category_cache">
        <Preference
            app:key="clear_empty"
            app:title="@string/pref_clear_empty"
            app:summary="@string/pref_clear_empty_summary" />

        <Preference
            app:key="clear_cache"
            app:title="@string/pref_clear_cache" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/pref_category_diagnostics">
        <Preference
            app:key="crash_log"
            app:title="@string/pref_crash_log" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/pref_category_about">
        <Preference
            app:key="check_update"
            app:title="@string/pref_check_update"
            app:summary="@string/pref_check_update_summary" />

        <Preference
            app:key="about"
            app:title="@string/pref_about" />
    </PreferenceCategory>
</PreferenceScreen>
