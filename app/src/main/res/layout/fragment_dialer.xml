<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 顶部输入区 -->
    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Material3.CardView.Filled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDisplay"
                    style="@style/TextAppearance.Material3.HeadlineSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/dialer_hint"
                    android:maxLines="1"
                    android:ellipsize="start" />

                <TextView
                    android:id="@+id/tvCallerId"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="?attr/colorPrimary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackspace"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 拨号键盘容器：占据中部剩余空间 键盘居中 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical">

            <LinearLayout style="@style/DialerRow">
                <include layout="@layout/dial_button" android:id="@+id/key1" />
                <include layout="@layout/dial_button" android:id="@+id/key2" />
                <include layout="@layout/dial_button" android:id="@+id/key3" />
            </LinearLayout>
            <LinearLayout style="@style/DialerRow">
                <include layout="@layout/dial_button" android:id="@+id/key4" />
                <include layout="@layout/dial_button" android:id="@+id/key5" />
                <include layout="@layout/dial_button" android:id="@+id/key6" />
            </LinearLayout>
            <LinearLayout style="@style/DialerRow">
                <include layout="@layout/dial_button" android:id="@+id/key7" />
                <include layout="@layout/dial_button" android:id="@+id/key8" />
                <include layout="@layout/dial_button" android:id="@+id/key9" />
            </LinearLayout>
            <LinearLayout style="@style/DialerRow">
                <include layout="@layout/dial_button" android:id="@+id/keyStar" />
                <include layout="@layout/dial_button" android:id="@+id/key0" />
                <include layout="@layout/dial_button" android:id="@+id/keyHash" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- 呼叫按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCall"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="@string/dialer_call"
        app:cornerRadius="28dp"
        app:iconGravity="textStart" />
</LinearLayout>
