<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1B1F"
    android:fitsSystemWindows="true">

    <!-- ===== 顶部：状态 / 时长 / 姓名 / SIM / 来电识别 ===== -->
    <TextView
        android:id="@+id/tvDuration"
        style="@style/TextAppearance.Material3.TitleMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:textColor="#E6E1E5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="00:42" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:textColor="#E6E1E5"
        android:textSize="36sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDuration"
        tools:text="腾讯公益" />

    <TextView
        android:id="@+id/tvSim"
        style="@style/TextAppearance.Material3.LabelLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:letterSpacing="0.08"
        android:text="@string/incall_sim1"
        android:textColor="#B3B0B6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvName" />

    <TextView
        android:id="@+id/tvCallerId"
        style="@style/TextAppearance.Material3.BodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="?attr/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSim" />

    <!-- ===== 大圆头像 ===== -->
    <FrameLayout
        android:id="@+id/avatarWrap"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_avatar_circle"
        app:layout_constraintBottom_toTopOf="@id/dockRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCallerId"
        app:layout_constraintVertical_bias="0.35">

        <com.mikepenz.iconics.view.IconicsImageView
            android:id="@+id/avatarIcon"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            app:iiv_color="#FFFFFF"
            app:iiv_icon="gmd-person" />
    </FrameLayout>

    <!-- ===== Dock 行：拨号键盘 / 静音 / 免提 / 更多 ===== -->
    <LinearLayout
        android:id="@+id/dockRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/hangupRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <include layout="@layout/in_call_dock_item" android:id="@+id/dockDialpad" />
        <include layout="@layout/in_call_dock_item" android:id="@+id/dockMute" />
        <include layout="@layout/in_call_dock_item" android:id="@+id/dockSpeaker" />
        <include layout="@layout/in_call_dock_item" android:id="@+id/dockMore" />
    </LinearLayout>

    <!-- ===== 挂断 / 接听-拒接 ===== -->
    <FrameLayout
        android:id="@+id/hangupRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 通话中：单个红药丸挂断 -->
        <FrameLayout
            android:id="@+id/btnHangup"
            android:layout_width="180dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_hangup_pill"
            android:clickable="true"
            android:focusable="true">

            <com.mikepenz.iconics.view.IconicsImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                app:iiv_color="#1C1B1F"
                app:iiv_icon="gmd-call_end" />
        </FrameLayout>

        <!-- 来电：左拒右接 -->
        <LinearLayout
            android:id="@+id/ringingRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <FrameLayout
                android:id="@+id/btnReject"
                android:layout_width="140dp"
                android:layout_height="64dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_hangup_pill"
                android:clickable="true"
                android:focusable="true">

                <com.mikepenz.iconics.view.IconicsImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    app:iiv_color="#1C1B1F"
                    app:iiv_icon="gmd-call_end" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnAnswer"
                android:layout_width="140dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_answer_pill"
                android:clickable="true"
                android:focusable="true">

                <com.mikepenz.iconics.view.IconicsImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    app:iiv_color="#1C1B1F"
                    app:iiv_icon="gmd-call" />
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
