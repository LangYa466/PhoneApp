<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#2B2930"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="20dp">

    <!-- 头：标题 + 关闭 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/incall_more_title"
            android:textColor="#E6E1E5"
            android:textSize="18sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseMore"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_close"
            app:iconTint="#E6E1E5" />
    </LinearLayout>

    <!-- 添加通话 -->
    <LinearLayout
        android:id="@+id/rowAddCall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_more_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_more_icon_circle">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_add_call"
                app:tint="#E6E1E5" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="@string/incall_more_add"
            android:textColor="#E6E1E5"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 保持通话 -->
    <LinearLayout
        android:id="@+id/rowHold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_more_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_more_icon_circle">

            <ImageView
                android:id="@+id/iconHold"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_pause"
                app:tint="#E6E1E5" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvHoldLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="@string/incall_more_hold"
            android:textColor="#E6E1E5"
            android:textSize="16sp" />
    </LinearLayout>
</LinearLayout>
