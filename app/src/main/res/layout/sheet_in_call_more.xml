<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurfaceContainer"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingBottom="12dp">

        <TextView
            style="@style/TextAppearance.Material3.TitleLarge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/incall_more_title"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseMore"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:iconSize="22dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rowAddCall"
        style="@style/Widget.CallerID.MoreRow">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_more_icon_circle">

            <com.mikepenz.iconics.view.IconicsImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                app:iiv_color="?attr/colorOnSurface"
                app:iiv_icon="mso-add_call" />
        </FrameLayout>

        <TextView
            style="@style/TextAppearance.Material3.BodyLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="@string/incall_more_add"
            android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rowHold"
        style="@style/Widget.CallerID.MoreRow"
        android:layout_marginTop="8dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_more_icon_circle">

            <com.mikepenz.iconics.view.IconicsImageView
                android:id="@+id/iconHold"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                app:iiv_color="?attr/colorOnSurface"
                app:iiv_icon="mso-pause" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvHoldLabel"
            style="@style/TextAppearance.Material3.BodyLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="@string/incall_more_hold"
            android:textColor="?attr/colorOnSurface" />
    </LinearLayout>
</LinearLayout>
